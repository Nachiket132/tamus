{
  "name": "temus",
  "version": "1.0.0",
  "description": "Blueprint your ideas before you build — the thinking layer before AI",
  "main": "src-electron/main.js",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently \"NODE_ENV=development vite\" \"sleep 2 && NODE_ENV=development electron .\"",
    "build": "vite build",
    "electron:build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.nonedesign.temus",
    "productName": "Temus",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "files": [
      "dist/**/*",
      "src-electron/**/*"
    ],
    "directories": {
      "buildResources": "public",
      "output": "release"
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^6.3.1"
  }
}
